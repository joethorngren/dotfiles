[init]
	defaultBranch = main

[user]
	name = oh_Henry
	email = joethorngren@gmail.com

[pull]
	rebase = false

[core]
	excludesfile = ~/.config/git/ignore

[delta]
	navigate = true
	line-numbers = true

[interactive]
	diffFilter = delta --color-only

[credential "https://github.com"]
	helper =
	helper = "!f() { gh auth git-credential \"$@\"; }; f"

[credential "https://gist.github.com"]
	helper =
	helper = "!f() { gh auth git-credential \"$@\"; }; f"

# Optional per-machine overrides (identity/work settings)
[include]
	path = ~/.gitconfig-local

# Optional per-machine overrides (identity/work settings)
[includeIf "gitdir:~/work/"]
	path = ~/.gitconfig-work
